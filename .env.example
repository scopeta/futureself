# FutureSelf — Environment Variables
#
# Copy this file to .env and fill in the values for your setup.
#
# Topology (spec §11): the agent runs only in the Foundry Hosted Agent container
# (main.py). The web BFF (web/app.py) calls that hosted agent over HTTP and owns
# the Postgres-backed Blueprint. So the two groups below configure two processes.

# ===========================================================================
# Hosted agent container (main.py) — where the LLM actually runs
# ===========================================================================

# --- Model (required by the agent) ---
# Anthropic direct: a Claude model id (current default below).
# Foundry: the model deployment name in your Foundry project.
FUTURESELF_MODEL=claude-opus-4-8

# --- LLM provider: Anthropic direct (default) ---
# Required when AZURE_FOUNDRY_ENDPOINT is not set.
ANTHROPIC_API_KEY=sk-ant-...

# --- LLM provider: Azure AI Foundry (optional) ---
# Set to use Foundry instead of Anthropic direct (FoundryChatClient, Entra ID
# auth via `az login` / managed identity).
# AZURE_FOUNDRY_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project-id>
#
# Injected by the Foundry platform on the deployed container — enables
# Foundry-managed storage (FoundryStorageProvider) in main.py.
# FOUNDRY_PROJECT_ENDPOINT=

# ===========================================================================
# Web BFF (web/app.py) — calls the hosted agent, owns persistence
# ===========================================================================

# --- Hosted agent endpoint (required by the BFF) ---
# Responses base URL of the deployed agent (the OpenAI-compatible endpoint).
# The BFF authenticates with Entra (managed identity / `az login`); the caller
# identity needs the Foundry User role on the agent resource.
FOUNDRY_AGENT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>/agents/<agent>/endpoint/protocols/openai
# Override the api-version query if needed (default: v1).
# FOUNDRY_AGENT_API_VERSION=v1

# --- Database (required by the BFF) ---
# Async PostgreSQL URL for the FastAPI backend.
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/futureself

# --- Web BFF (optional) ---
# Comma-separated CORS origins for the React frontend (defaults to same-origin).
# ALLOWED_ORIGINS=http://localhost:5173

# --- Telemetry (optional, Azure Monitor) ---
# Connection string from Foundry portal → Settings → Tracing.
# APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- Hardening (optional) ---
# Per-IP requests per minute on /api/* (0 disables the limiter).
# RATE_LIMIT_PER_MIN=30
