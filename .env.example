# FutureSelf — Environment Variables
#
# Copy this file to .env and fill in the values for your setup.

# --- Model ---
# Deployment name of the model in your Azure AI Foundry project.
# Can be any model available in Foundry (Claude, GPT-4o, Grok, etc.)
FUTURESELF_MODEL=claude-opus-4-6

# --- Azure AI Foundry ---
# Project endpoint from the Foundry portal (Overview tab).
AZURE_FOUNDRY_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project-id>
# AZURE_FOUNDRY_API_KEY=   # omit to use Entra ID (az login / managed identity)

# --- Telemetry (Azure Monitor) ---
# Connection string from Foundry portal → Settings → Tracing.
# APPLICATIONINSIGHTS_CONNECTION_STRING=
