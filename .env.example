# FutureSelf — Environment Variables
#
# Copy this file to .env and fill in the values for your setup.
# The active deployment uses Anthropic direct (Claude). The Azure AI Foundry
# block below is optional — leave it commented unless you deploy via Foundry.

# --- Model (required) ---
# Model name passed to the configured provider.
# Anthropic direct: a Claude model id (current default below).
# Foundry: the model deployment name in your Foundry project.
FUTURESELF_MODEL=claude-opus-4-8

# --- LLM provider: Anthropic direct (default) ---
# Required when AZURE_FOUNDRY_ENDPOINT is not set.
ANTHROPIC_API_KEY=sk-ant-...

# --- LLM provider: Azure AI Foundry (optional) ---
# Set AZURE_FOUNDRY_ENDPOINT to use Foundry instead of Anthropic direct.
# When set, the orchestrator and the Responses host both switch to
# FoundryChatClient (Entra ID auth via `az login` / managed identity).
# AZURE_FOUNDRY_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project-id>
#
# Set on the Foundry Hosted Agent container only — enables Foundry-managed
# thread memory (FoundryStorageProvider) in main.py instead of the in-memory store.
# FOUNDRY_PROJECT_ENDPOINT=

# --- Database (required by the web BFF) ---
# Async PostgreSQL URL. Not needed for the in-process orchestrator/simulate.py,
# but required to run the FastAPI backend (web/app.py).
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/futureself

# --- Web BFF (optional) ---
# Comma-separated CORS origins for the React frontend (defaults to same-origin).
# ALLOWED_ORIGINS=http://localhost:5173

# --- Telemetry (optional, Azure Monitor) ---
# Connection string from Foundry portal → Settings → Tracing.
# APPLICATIONINSIGHTS_CONNECTION_STRING=
