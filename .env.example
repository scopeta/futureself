# FutureSelf — Environment Variables
#
# Copy this file to .env and fill in the values for your setup.

# --- LLM Provider (legacy single-provider mode) ---
# Used when no routing YAML is configured.
FUTURESELF_LLM_PROVIDER=openai          # openai | anthropic | google | azure_foundry
FUTURESELF_LLM_MODEL=gpt-5-nano         # model name (overrides provider default)

# --- OpenAI / OpenAI-compatible ---
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://models.inference.ai.azure.com   # GitHub Models
# OPENAI_MAX_CONCURRENT=4

# --- Anthropic ---
# ANTHROPIC_API_KEY=

# --- Google Gemini ---
# GOOGLE_API_KEY=
# GEMINI_RPM=15

# --- Azure AI Foundry ---
# AZURE_FOUNDRY_ENDPOINT=https://<account>.services.ai.azure.com
# AZURE_FOUNDRY_API_KEY=                                          # omit to use Entra ID (az login)
# AZURE_FOUNDRY_MAX_CONCURRENT=10

# --- Model Routing ---
# Path to routing YAML. Omit to use config/routing.yaml or fall back to single-provider.
# FUTURESELF_ROUTING_CONFIG=config/routing.yaml

# --- Telemetry (Azure Monitor) ---
# APPLICATIONINSIGHTS_CONNECTION_STRING=
